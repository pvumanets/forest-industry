# Скопируйте в .env и при необходимости смените пароль и строки подключения.
# Логин/пароль/имя БД в URL должны совпадать с POSTGRES_*.

POSTGRES_USER=grove
# смените в .env
POSTGRES_PASSWORD=change_me
POSTGRES_DB=grove_pulse

# Синхронное подключение (Alembic, сиды, текущий sync-стек SQLAlchemy в API)
DATABASE_URL=postgresql+psycopg://grove:change_me@db:5432/grove_pulse
# Для Alembic; при psycopg можно дублировать DATABASE_URL
DATABASE_URL_SYNC=postgresql+psycopg://grove:change_me@db:5432/grove_pulse

# Сиды: задайте пароли или для локальной разработки (не для публичного git):
# ALLOW_INSECURE_SEED_DEFAULTS=1
# Либо одна переменная на всех:
# SEED_DEFAULT_PASSWORD=your_dev_password
# Либо по логинам:
# SEED_PASSWORD_ADMIN=...
# SEED_PASSWORD_EVGENIY=...
# SEED_PASSWORD_PAVEL=...
# SEED_PASSWORD_MARKETING=...
# SEED_PASSWORD_MANAGER=...

# Порт фронта на хосте (внутри контейнера Vite остаётся 5173). По умолчанию 5174 — чтобы не конфликтовать с другим Vite на 5173.
WEB_HOST_PORT=5174

# CORS (credentials); через запятую — укажите origin фронта (локальный pnpm dev часто :5173, Docker web — WEB_HOST_PORT)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174

# Cookie Secure: true при ENVIRONMENT=production или COOKIE_SECURE=true
ENVIRONMENT=development
# COOKIE_SECURE=true
